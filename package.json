{
	"name": "jobapptracker",
	"version": "0.4.0",
	"private": true,
	"repository": "https://github.com/graffhyrum/jobapptracker",
	"type": "module",
	"module": "src/index.ts",
	"scripts": {
		"start": "bun run dist/jobapptracker",
		"dev": "bun run build:scripts && bun --watch run src/index.ts",
		"build": "bun run build:scripts && bun build src/index.ts --target bun --outfile dist/jobapptracker",
		"build:scripts": "bun build src/presentation/scripts/feature-flags.ts --target browser --outfile src/presentation/scripts/feature-flags.js  && bun build src/presentation/scripts/pipeline-client.ts --target browser --outfile src/presentation/scripts/pipeline-client.js",
		"watch:scripts": "bun --watch src/presentation/scripts/feature-flags.ts src/presentation/scripts/pipeline-client.ts --bun \"bun run build:scripts\"",
		"test:all": "bun test:coverage && bun test:e2e",
		"test:unit": "bun test",
		"test:unit:ai": "bun test",
		"test:coverage": "bun test --coverage",
		"test:coverage:ai": "bun test --coverage",
		"test:e2e": "bun scripts/end-to-end.ts",
		"test:e2e:ui": "bun test:e2e --ui",
		"lint": "bunx oxlint",
		"format": "bunx oxfmt",
		"check": "bunx oxlint && bunx oxfmt --check",
		"fix": "bunx oxlint --fix && bunx oxfmt",
		"fixx": "bunx oxlint --fix --fix-suggestions --fix-dangerously && bunx oxfmt",
		"typecheck": "tsc --noEmit",
		"fastvet": "bun typecheck && bun fix && stepdown-rule fix src/ && stepdown-rule analyze src/ && rule-validator 'src/**/*.ts' && bun run test:unit:ai",
		"vet": "bun fastvet && bun test:e2e"
	},
	"dependencies": {
		"@elysiajs/html": "^1.4.0",
		"@elysiajs/static": "^1.4.7",
		"@elysiajs/swagger": "^1.3.1",
		"arktype": "^2.2.0",
		"dotenv": "^17.3.1",
		"elysia": "^1.4.28"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@faker-js/faker": "^10.3.0",
		"@happy-dom/global-registrator": "^20.8.4",
		"@playwright/test": "^1.58.2",
		"@types/bun": "^1.3.10",
		"@types/node": "^24.12.0",
		"@typescript/native-preview": "^7.0.0-dev.20260316.1",
		"find-process": "^2.1.0",
		"htmx.org": "^2.0.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"memfs": "^4.56.11",
		"neverthrow": "^8.2.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"tree-kill": "^1.2.2"
	},
	"lint-staged": {
		"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": [
			"bunx oxlint --fix",
			"bunx oxfmt"
		]
	}
}
