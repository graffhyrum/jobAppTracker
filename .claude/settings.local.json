{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Bash(CLAUDECODE=1 bun test src/domain/use-cases/analytics.test.ts)",
			"WebFetch(domain:biomejs.dev)",
			"WebFetch(domain:www.jetbrains.com)",
			"WebFetch(domain:eslint.org)",
			"Bash(oxfmt:*)",
			"Bash(oxlint --help)",
			"Bash(CLAUDECODE=1 bun test)",
			"Bash(cp src/domain/use-cases/analytics-aggregator.ts /tmp/ag-before.ts)",
			"Read(//tmp/**)"
		],
		"defaultMode": "bypassPermissions"
	}
}
